<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{{ wireguard_launchd_label }}</string>
    <key>ProgramArguments</key>
    <array>
        <string>{{ wireguard_config_dir }}/wg-up.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardOutPath</key>
    <string>{{ wireguard_config_dir }}/wireguard.log</string>
    <key>StandardErrorPath</key>
    <string>{{ wireguard_config_dir }}/wireguard.error.log</string>
</dict>
</plist>
