# Pangolin VPS Environment Variables
# Generated by Ansible
# Contains sensitive configuration - do not commit to git

# Pangolin secrets
PANGOLIN_SECRET={{ pangolin_secret }}
ADMIN_PASSWORD={{ apps.pangolin.admin_password | default(lookup('password', '/dev/null chars=ascii_letters,digits length=32')) }}

# WireGuard keys
WG_PRIVATE_KEY={{ wireguard_server_private_key }}
WG_PUBLIC_KEY={{ wireguard_server_public_key }}

# Traefik credentials
TRAEFIK_PASSWORD={{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}

# SMTP credentials (if configured)
{% if smtp is defined and smtp.password is defined %}
SMTP_PASSWORD={{ smtp.password }}
{% else %}
SMTP_PASSWORD=
{% endif %}

# Domain
DOMAIN={{ domain.public }}
LETSENCRYPT_EMAIL={{ tls.letsencrypt.email }}
