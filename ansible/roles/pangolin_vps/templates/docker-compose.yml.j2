# Pangolin VPS Docker Stack
# Generated by Ansible
# Includes: Pangolin Server, Gerbil (WireGuard orchestrator), Traefik (edge router)

services:
  # ==========================================================================
  # TRAEFIK - Edge Router with Let's Encrypt
  # ==========================================================================
  traefik:
    image: traefik:{{ traefik_version }}
    container_name: traefik
    restart: {{ docker_restart_policy }}
    ports:
      - "{{ traefik_http_port }}:80"
      - "{{ traefik_https_port }}:443"
      - "{{ traefik_admin_port }}:8080"
    volumes:
      - {{ traefik_config_dir }}/traefik.yml:/etc/traefik/traefik.yml:ro
      - {{ traefik_config_dir }}/dynamic:/etc/traefik/dynamic:ro
      - {{ letsencrypt_dir }}:/letsencrypt
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - {{ docker_network_name }}
    environment:
      - TZ=UTC
      - DOCKER_API_VERSION=1.44
    labels:
      - "traefik.enable=true"
      # Traefik Dashboard
      - "traefik.http.routers.traefik-dashboard.rule=Host(`traefik.{{ domain.public }}`)"
      - "traefik.http.routers.traefik-dashboard.entrypoints=websecure"
      - "traefik.http.routers.traefik-dashboard.tls=true"
      - "traefik.http.routers.traefik-dashboard.tls.certresolver=letsencrypt"
      - "traefik.http.routers.traefik-dashboard.service=api@internal"
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
      start_period: {{ healthcheck_start_period }}
    logging:
      driver: json-file
      options:
        max-size: "{{ log_max_size }}"
        max-file: "{{ log_max_file }}"

  # ==========================================================================
  # PANGOLIN - WireGuard VPN Server
  # ==========================================================================
  pangolin:
    image: fosrl/pangolin:{{ pangolin_version }}
    container_name: pangolin
    restart: {{ docker_restart_policy }}
    ports:
      - "{{ wireguard_port }}:51820/udp"
    volumes:
      - {{ pangolin_data_dir }}:/app/config
    environment:
      - PANGOLIN_DOMAIN={{ domain.public }}
    env_file:
      - .env
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv6.conf.all.forwarding=1
    networks:
      - {{ docker_network_name }}
    labels:
      - "traefik.enable=true"
      # Pangolin Admin UI
      - "traefik.http.routers.pangolin.rule=Host(`pangolin.{{ domain.public }}`)"
      - "traefik.http.routers.pangolin.entrypoints=websecure"
      - "traefik.http.routers.pangolin.tls=true"
      - "traefik.http.routers.pangolin.tls.certresolver=letsencrypt"
      - "traefik.http.services.pangolin.loadbalancer.server.port=3000"
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:3002/"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
      start_period: 30s
    logging:
      driver: json-file
      options:
        max-size: "{{ log_max_size }}"
        max-file: "{{ log_max_file }}"

  # ==========================================================================
  # GERBIL - WireGuard Tunnel Orchestrator
  # ==========================================================================
  gerbil:
    image: fosrl/gerbil:{{ gerbil_version }}
    container_name: gerbil
    restart: {{ docker_restart_policy }}
    command:
      - --reachableAt=http://gerbil:3004
      - --generateAndSaveKeyTo=/var/config/key
      - --remoteConfig=http://pangolin:3001/api/v1/
    volumes:
      - {{ pangolin_data_dir }}:/var/config
    ports:
      - "3004:3004"
    environment:
      - TZ=UTC
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    sysctls:
      - net.ipv4.ip_forward=1
      - net.ipv4.conf.all.src_valid_mark=1
    depends_on:
      pangolin:
        condition: service_healthy
    networks:
      - {{ docker_network_name }}
    healthcheck:
      test: ["CMD", "pgrep", "-f", "gerbil"]
      interval: {{ healthcheck_interval }}
      timeout: {{ healthcheck_timeout }}
      retries: {{ healthcheck_retries }}
      start_period: {{ healthcheck_start_period }}
    logging:
      driver: json-file
      options:
        max-size: "{{ log_max_size }}"
        max-file: "{{ log_max_file }}"

networks:
  {{ docker_network_name }}:
    external: true
