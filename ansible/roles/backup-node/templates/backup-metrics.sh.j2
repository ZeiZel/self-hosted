#!/bin/bash
# Backup metrics for Prometheus node_exporter textfile collector
# Generated by Ansible - Do not edit manually

set -e

# Configuration
RESTIC_REPO="{{ nfs_restic_dir }}"
RESTIC_PASSWORD_FILE="{{ nfs_exports_dir }}/.restic-password"
BACKUP_DIR="{{ nfs_exports_dir }}"

# Get disk usage
DISK_TOTAL=$(df -B1 "$BACKUP_DIR" | tail -1 | awk '{print $2}')
DISK_USED=$(df -B1 "$BACKUP_DIR" | tail -1 | awk '{print $3}')
DISK_AVAIL=$(df -B1 "$BACKUP_DIR" | tail -1 | awk '{print $4}')

echo "# HELP backup_disk_total_bytes Total disk space for backups"
echo "# TYPE backup_disk_total_bytes gauge"
echo "backup_disk_total_bytes $DISK_TOTAL"

echo "# HELP backup_disk_used_bytes Used disk space for backups"
echo "# TYPE backup_disk_used_bytes gauge"
echo "backup_disk_used_bytes $DISK_USED"

echo "# HELP backup_disk_available_bytes Available disk space for backups"
echo "# TYPE backup_disk_available_bytes gauge"
echo "backup_disk_available_bytes $DISK_AVAIL"

# Get Restic repository stats
if [ -f "$RESTIC_PASSWORD_FILE" ]; then
    export RESTIC_REPOSITORY="$RESTIC_REPO"
    export RESTIC_PASSWORD_FILE

    # Count snapshots
    SNAPSHOT_COUNT=$(restic snapshots --json 2>/dev/null | jq 'length' || echo 0)
    echo "# HELP backup_restic_snapshots_total Number of Restic snapshots"
    echo "# TYPE backup_restic_snapshots_total gauge"
    echo "backup_restic_snapshots_total $SNAPSHOT_COUNT"

    # Get latest snapshot timestamp
    LATEST_TIMESTAMP=$(restic snapshots --latest 1 --json 2>/dev/null | jq -r '.[0].time // empty' | xargs -I{} date -d {} +%s 2>/dev/null || echo 0)
    echo "# HELP backup_restic_latest_timestamp_seconds Timestamp of latest backup"
    echo "# TYPE backup_restic_latest_timestamp_seconds gauge"
    echo "backup_restic_latest_timestamp_seconds $LATEST_TIMESTAMP"

    # Repository size
    REPO_SIZE=$(du -sb "$RESTIC_REPO" 2>/dev/null | awk '{print $1}' || echo 0)
    echo "# HELP backup_restic_repository_bytes Size of Restic repository"
    echo "# TYPE backup_restic_repository_bytes gauge"
    echo "backup_restic_repository_bytes $REPO_SIZE"
fi

# NFS export status
NFS_EXPORTS=$(exportfs -v 2>/dev/null | wc -l || echo 0)
echo "# HELP backup_nfs_exports_total Number of active NFS exports"
echo "# TYPE backup_nfs_exports_total gauge"
echo "backup_nfs_exports_total $NFS_EXPORTS"

# Database dumps count
PG_DUMPS=$(find {{ nfs_dumps_dir }}/postgres -name "*.sql.gz" 2>/dev/null | wc -l || echo 0)
MONGO_DUMPS=$(find {{ nfs_dumps_dir }}/mongodb -name "*.archive.gz" 2>/dev/null | wc -l || echo 0)

echo "# HELP backup_postgres_dumps_total Number of PostgreSQL dumps"
echo "# TYPE backup_postgres_dumps_total gauge"
echo "backup_postgres_dumps_total $PG_DUMPS"

echo "# HELP backup_mongodb_dumps_total Number of MongoDB dumps"
echo "# TYPE backup_mongodb_dumps_total gauge"
echo "backup_mongodb_dumps_total $MONGO_DUMPS"
