[Unit]
Description=Traefik Edge Router (Gateway)
Documentation=https://doc.traefik.io/traefik/
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root

# Working directory
WorkingDirectory={{ traefik_config_dir }}

# Executable
ExecStartPre=/bin/mkdir -p {{ traefik_config_dir }}/dynamic
ExecStartPre=/bin/mkdir -p /var/log/traefik
ExecStartPre=/bin/sh -c "touch {{ traefik_config_dir }}/acme.json && chmod 600 {{ traefik_config_dir }}/acme.json"
ExecStart={{ pangolin_install_dir }}/traefik --configFile={{ traefik_config_dir }}/traefik.yml

# Restart policy
Restart=always
RestartSec=10s

# Capabilities for binding to privileged ports
AmbientCapabilities=CAP_NET_BIND_SERVICE

# Limits
LimitNOFILE=1048576
LimitNPROC=512

[Install]
WantedBy=multi-user.target
