---
# Traefik Edge Router Configuration (Gateway VPS)
# Generated by Ansible

# Global configuration
global:
  checkNewVersion: false
  sendAnonymousUsage: false

# Entry points
entryPoints:
  web:
    address: ":{{ traefik_http_port }}"
    # Note: No global redirect - ACME HTTP-01 challenges require port 80
    # HTTPS redirect is handled per-route in dynamic config

  websecure:
    address: ":{{ traefik_https_port }}"
    http:
      tls:
        certResolver: letsencrypt
        domains:
          - main: {{ domain.public }}
            sans:
              - "*.{{ domain.public }}"

  traefik:
    address: ":{{ traefik_dashboard_port }}"

# Certificate resolvers
certificatesResolvers:
  letsencrypt:
    acme:
      email: {{ tls.letsencrypt.email }}
      storage: {{ traefik_config_dir }}/acme.json
      httpChallenge:
        entryPoint: web

# API and dashboard
api:
  dashboard: true
  insecure: true

# Ping health check
ping:
  entryPoint: traefik

# Logging
log:
  level: INFO

# Providers
providers:
  # File provider for dynamic configuration
  file:
    directory: {{ traefik_config_dir }}/dynamic
    watch: true
