---
# =============================================================================
# KUBESPRAY INVENTORY
# =============================================================================
# Generated by Ansible from hosts.ini inventory
# Do not edit manually - regenerate with: ansible-playbook -i inventory all.yml --tags kubespray,prepare

all:
  hosts:
{% for host in groups['masters'] + groups['workers'] %}
    {{ host }}:
      ansible_host: {{ hostvars[host]['ansible_host'] }}
      ansible_user: {{ hostvars[host]['ansible_user'] }}
      ansible_port: {{ hostvars[host]['ansible_port'] | default(22) }}
      ip: {{ hostvars[host]['ansible_host'] }}
      access_ip: {{ hostvars[host]['ansible_host'] }}
{% if hostvars[host]['ansible_become_password'] is defined %}
      ansible_become_password: {{ hostvars[host]['ansible_become_password'] }}
{% endif %}
{% if hostvars[host]['ansible_ssh_private_key_file'] is defined %}
      ansible_ssh_private_key_file: {{ hostvars[host]['ansible_ssh_private_key_file'] }}
{% endif %}
{% if hostvars[host]['ansible_ssh_common_args'] is defined %}
      ansible_ssh_common_args: '{{ hostvars[host]['ansible_ssh_common_args'] }}'
{% endif %}
{% endfor %}

  children:
    # Kubernetes control plane nodes
    kube_control_plane:
      hosts:
{% for host in groups['masters'] %}
        {{ host }}:
{% endfor %}

    # Kubernetes worker nodes (includes control plane for workload scheduling)
    kube_node:
      hosts:
{% for host in groups['masters'] + groups['workers'] %}
        {{ host }}:
{% endfor %}

    # ETCD cluster nodes
    etcd:
      hosts:
{% for host in groups['masters'] %}
        {{ host }}:
{% endfor %}

    # Kubernetes cluster (union of control plane and nodes)
    k8s_cluster:
      children:
        kube_control_plane:
        kube_node:

    # Calico Route Reflector (empty for small clusters)
    calico_rr:
      hosts: {}
