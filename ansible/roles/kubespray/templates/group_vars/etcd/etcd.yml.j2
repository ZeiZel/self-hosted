---
# =============================================================================
# KUBESPRAY ETCD.YML CONFIGURATION
# =============================================================================
# Generated by Ansible
# Reference: https://kubespray.io/#/docs/ansible/vars

# -----------------------------------------------------------------------------
# ETCD Deployment
# -----------------------------------------------------------------------------
## ETCD deployment type: host, kubeadm, docker
etcd_deployment_type: {{ etcd_deployment_type }}

## ETCD member name prefix
etcd_member_name: "etcd"

## ETCD data directory
etcd_data_dir: /var/lib/etcd

# -----------------------------------------------------------------------------
# ETCD Performance
# -----------------------------------------------------------------------------
## ETCD quota backend bytes (default 2GB)
etcd_quota_backend_bytes: "2147483648"

## ETCD compaction
etcd_compaction_retention: "8"

## ETCD memory limit
etcd_memory_limit: 0

# -----------------------------------------------------------------------------
# ETCD Security
# -----------------------------------------------------------------------------
## Enable ETCD peer client cert auth
etcd_peer_client_cert_auth: true

## ETCD cert validity duration
# etcd_cert_validity_duration: 365
