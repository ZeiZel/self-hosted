---
# =============================================================================
# KUBESPRAY ALL.YML CONFIGURATION
# =============================================================================
# Generated by Ansible
# Reference: https://kubespray.io/#/docs/ansible/vars

# -----------------------------------------------------------------------------
# Basic Configuration
# -----------------------------------------------------------------------------
## Cluster name
cluster_name: {{ cluster_name }}

## Directory to store downloaded files
download_cache_dir: /tmp/kubespray_cache

## Download settings
download_run_once: true
download_localhost: false

## Retry configuration
download_retries: 4

# -----------------------------------------------------------------------------
# Upstream DNS Configuration
# -----------------------------------------------------------------------------
## Upstream DNS servers
upstream_dns_servers:
  - 8.8.8.8
  - 8.8.4.4

## Use host resolv.conf
disable_localhost_dns: false

# -----------------------------------------------------------------------------
# Loadbalancer Configuration
# -----------------------------------------------------------------------------
## Enable internal loadbalancer for apiservers
loadbalancer_apiserver_localhost: true
loadbalancer_apiserver_type: nginx  # nginx/haproxy

## Use localhost for loadbalancer
loadbalancer_apiserver_port: 6443

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
## Kubernetes authentication modes
kube_oidc_auth: false
kube_basic_auth: false

# -----------------------------------------------------------------------------
# Audit Logging
# -----------------------------------------------------------------------------
## Enable audit logging
kubernetes_audit: false

# -----------------------------------------------------------------------------
# Cloud Provider
# -----------------------------------------------------------------------------
## Cloud provider: leave unset for bare metal
## Valid options: gce, aws, azure, openstack, vsphere, oci, external
# cloud_provider:

# -----------------------------------------------------------------------------
# Additional Configuration
# -----------------------------------------------------------------------------
## Enable supplementary addresses in SSL cert
## VPN IP for remote CLI access
supplementary_addresses_in_ssl_keys:
  - "10.99.0.10"

## Cert expiration (default 1 year)
# kube_cert_validity_duration: 365

## Preinstall OS configuration
preinstall_selinux_state: disabled

## Skip confirmation
skip_confirmation: true
