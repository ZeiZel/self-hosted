---
# =============================================================================
# KUBESPRAY ADDONS.YML CONFIGURATION
# =============================================================================
# Generated by Ansible
# Reference: https://kubespray.io/#/docs/ansible/vars

# -----------------------------------------------------------------------------
# Helm
# -----------------------------------------------------------------------------
## Enable Helm installation
helm_enabled: {{ helm_enabled }}

# -----------------------------------------------------------------------------
# Metrics Server
# -----------------------------------------------------------------------------
## Enable Metrics Server
metrics_server_enabled: {{ metrics_server_enabled }}
metrics_server_kubelet_insecure_tls: true
metrics_server_kubelet_preferred_address_types: "InternalIP,ExternalIP,Hostname"

# -----------------------------------------------------------------------------
# Ingress Controllers
# -----------------------------------------------------------------------------
## NGINX Ingress Controller (disabled - using Traefik via Helmfile)
ingress_nginx_enabled: false

## ALB Ingress Controller
ingress_alb_enabled: false

# -----------------------------------------------------------------------------
# Cert Manager
# -----------------------------------------------------------------------------
## Cert Manager (disabled - managed via Helmfile)
cert_manager_enabled: false

# -----------------------------------------------------------------------------
# MetalLB
# -----------------------------------------------------------------------------
## MetalLB Load Balancer (disabled for this setup)
metallb_enabled: false

# -----------------------------------------------------------------------------
# Storage Provisioners
# -----------------------------------------------------------------------------
## Local Path Provisioner (disabled - using OpenEBS)
local_path_provisioner_enabled: false

## Local Volume Provisioner
local_volume_provisioner_enabled: false

# -----------------------------------------------------------------------------
# Network Policies
# -----------------------------------------------------------------------------
{% if cni_plugin == 'calico' %}
## Calico Network Policy Controller
calico_policy_enabled: true
{% endif %}

# -----------------------------------------------------------------------------
# CoreDNS
# -----------------------------------------------------------------------------
## NodeLocal DNS Cache
nodelocaldns_enabled: true

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
## Kubernetes Dashboard (disabled - using Grafana)
dashboard_enabled: false

# -----------------------------------------------------------------------------
# Registry
# -----------------------------------------------------------------------------
## Container Registry (disabled - using Harbor via Helmfile)
registry_enabled: false

# -----------------------------------------------------------------------------
# ArgoCD
# -----------------------------------------------------------------------------
## ArgoCD (disabled - managed separately)
argocd_enabled: false

# -----------------------------------------------------------------------------
# Krew
# -----------------------------------------------------------------------------
## Krew kubectl plugin manager
krew_enabled: false
