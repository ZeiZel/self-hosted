---
# =============================================================================
# KUBESPRAY K8S-CLUSTER.YML CONFIGURATION
# =============================================================================
# Generated by Ansible
# Reference: https://kubespray.io/#/docs/ansible/vars

# -----------------------------------------------------------------------------
# Kubernetes Version and Components
# -----------------------------------------------------------------------------
## Kubernetes version
kube_version: {{ kube_version }}

## Container runtime: containerd, crio, docker
container_manager: {{ container_manager }}

## Kube-proxy mode: iptables, ipvs
kube_proxy_mode: {{ kube_proxy_mode }}

## Kube-proxy strict ARP (required for MetalLB)
kube_proxy_strict_arp: true

# -----------------------------------------------------------------------------
# Network Plugin
# -----------------------------------------------------------------------------
## Network plugin: calico, cilium, flannel, weave, etc.
kube_network_plugin: {{ cni_plugin }}

## Pod network CIDR
kube_pods_subnet: {{ pod_cidr }}

## Service network CIDR
kube_service_addresses: {{ service_cidr }}

## Network node prefix (pods per node)
kube_network_node_prefix: 24

{% if cni_plugin == 'calico' %}
# -----------------------------------------------------------------------------
# Calico Configuration
# -----------------------------------------------------------------------------
## Calico IP-in-IP mode: Always, CrossSubnet, Never
calico_ipip_mode: 'Always'

## Calico VXLAN mode: Always, CrossSubnet, Never
calico_vxlan_mode: 'Never'

## Calico network backend: bird, vxlan, none
calico_network_backend: 'bird'

## Enable Calico eBPF dataplane
calico_bpf_enabled: false

## Calico Felix configuration
calico_felix_prometheusmetricsenabled: true
{% endif %}

# -----------------------------------------------------------------------------
# DNS Configuration
# -----------------------------------------------------------------------------
## DNS mode: coredns, coredns_dual, manual, none
dns_mode: {{ dns_mode }}

## Enable NodeLocal DNS cache
enable_nodelocaldns: true
nodelocaldns_ip: 169.254.25.10

## CoreDNS replicas
coredns_replicas_autoscaler: true
coredns_min_replicas: 2

# -----------------------------------------------------------------------------
# Kubelet Configuration
# -----------------------------------------------------------------------------
## Kubelet deployment type
kubelet_deployment_type: host

## Kubelet max pods
kubelet_max_pods: 110

## Kubelet CPU and memory management
kubelet_cpu_manager_policy: none
kubelet_topology_manager_policy: none

# -----------------------------------------------------------------------------
# Resource Reservations
# -----------------------------------------------------------------------------
## System reserved resources
system_reserved: true
system_memory_reserved: 512Mi
system_cpu_reserved: 500m

## Kube reserved resources
kube_reserved: true
kube_memory_reserved: 256Mi
kube_cpu_reserved: 100m

## Eviction thresholds
eviction_hard:
  memory.available: "100Mi"
  nodefs.available: "10%"
  imagefs.available: "10%"

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
## Authorization modes
authorization_modes:
  - Node
  - RBAC

## Anonymous authentication
kube_api_anonymous_auth: false

## Admission plugins
kube_apiserver_enable_admission_plugins:
  - NodeRestriction
  - ServiceAccount
  - PodSecurity

## Pod Security Standards (Kubernetes 1.25+)
kube_apiserver_pod_security_admission_configuration_enabled: true

# -----------------------------------------------------------------------------
# Controller Manager Configuration
# -----------------------------------------------------------------------------
## Enable garbage collection
kubelet_garbage_collector_enabled: true

# -----------------------------------------------------------------------------
# Feature Gates
# -----------------------------------------------------------------------------
kube_feature_gates:
  - "RotateKubeletServerCertificate=true"

# -----------------------------------------------------------------------------
# Kubeconfig
# -----------------------------------------------------------------------------
## Copy kubeconfig to localhost
kubeconfig_localhost: true
kubectl_localhost: true

## Write kubeconfig with cluster FQDN
# kubeconfig_file: "/root/.kube/config"

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
## Enable encryption at rest
kube_encrypt_secret_data: false
