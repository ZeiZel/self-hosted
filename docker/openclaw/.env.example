# OpenClaw Docker Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: LLM Provider API Keys (at least one required)
# =============================================================================

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API Key (optional, for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# REQUIRED: Gateway Authentication
# =============================================================================

# Gateway token for securing the OpenClaw API
# Generate with: openssl rand -hex 32
GATEWAY_TOKEN=

# =============================================================================
# OPTIONAL: Service Configuration
# =============================================================================

# OpenClaw version
OPENCLAW_VERSION=1.0.0

# Web UI port
OPENCLAW_PORT=18789

# OAuth callback port
OPENCLAW_OAUTH_PORT=1455

# Extra apt packages to install (space-separated)
OPENCLAW_DOCKER_APT_PACKAGES=

# Extra host bind mounts
OPENCLAW_EXTRA_MOUNTS=

# =============================================================================
# OPTIONAL: Nginx Proxy (when using with-proxy profile)
# =============================================================================

NGINX_HTTPS_PORT=443
NGINX_HTTP_PORT=80
