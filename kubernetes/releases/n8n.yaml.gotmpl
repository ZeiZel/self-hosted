# n8n release overrides.
# Base config lives in charts/n8n/values.yaml under the "chart-base:" key.
# Add env-specific overrides here, nested under "chart-base:" (subchart scoping).
# Example:
#   chart-base:
#     workloads:
#       - containers:
#           - name: n8n
#             env:
#               - name: EXAMPLE
#                 value: "value"
